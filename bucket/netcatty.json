{
    "version": "1.1.32",
    "description": "A modern SSH client, SFTP browser, and terminal manager with a built-in AI agent. Native on macOS, Windows, and Linux. Open source.",
    "homepage": "https://netcatty.app",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.32/Netcatty-1.1.32-win-x64.exe#/dl.7z",
            "hash": "3899825c68e5139670aeee8b7d5c754391ba1633da2045e76ec320e8819fc4ec"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.32/Netcatty-1.1.32-win-arm64.exe#/dl.7z",
            "hash": "5a3b3e12fb1fade9cdaa4b3a31ce34b8fe762eb1ee8dac69a700614aea0acab4"
        }
    },
    "extract_dir": "$PLUGINSDIR",
    "pre_install": [
        "Remove-Item \"$dir\\*\" -Exclude \"app*.7z\"",
        "Get-Item \"$dir\\app*.7z\" | Expand-7zipArchive -Destination \"$dir\" -Removal"
    ],
    "persist": "User Data",
    "shortcuts": [
        [
            "Netcatty.exe",
            "Netcatty",
            "--user-data-dir=\"$persist_dir\\User Data\""
        ]
    ],
    "checkver": {
        "github": "https://github.com/binaricat/Netcatty"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-x64.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-arm64.exe#/dl.7z"
            }
        }
    }
}
